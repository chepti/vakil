APP_NAME="משפחת ואקיל"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://vakil.test

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vakil
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=noreply@vakil.chepti.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=noreply@vakil.chepti.com
MAIL_FROM_NAME="משפחת ואקיל"

# Invitation token expiry in days
INVITATION_EXPIRY_DAYS=7

# Max upload size in KB (default 5MB)
MAX_UPLOAD_KB=5120
